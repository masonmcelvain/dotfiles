#!/usr/bin/env bash
# Helix formatter: uses biome or prettier based on project config.
# Usage: hx-fmt <ext>
# Reads stdin, writes formatted output to stdout.

ext="${1:?Usage: hx-fmt <ext>}"

# Buffer stdin so we can fall back to it verbatim on any failure.
tmp="$(mktemp -d)" || { cat; exit 0; }
trap 'rm -rf "$tmp"' EXIT
cat >"$tmp/in"

# Emit the original input unchanged and stop.
passthrough() { cat "$tmp/in"; exit 0; }

# Walk up from cwd to find a formatter config file.
has_prettier_config() {
  for f in .prettierrc .prettierrc.{json,yml,yaml,json5,js,cjs,mjs,toml} \
           prettier.config.{js,cjs,mjs}; do
    [ -f "$1/$f" ] && return 0
  done
  return 1
}

# Find an executable in the nearest node_modules/.bin walking up from $PWD.
find_local_bin() {
  local name="$1" d="$PWD"
  while [ "$d" != "/" ]; do
    if [ -x "$d/node_modules/.bin/$name" ]; then
      printf '%s\n' "$d/node_modules/.bin/$name"
      return 0
    fi
    d="$(dirname "$d")"
  done
  return 1
}

# Run a formatter; on success with non-empty output, print it (preserving exact
# bytes, including the trailing newline) and exit. Otherwise return non-zero so
# the caller can fall through to passthrough.
run_formatter() {
  "$@" <"$tmp/in" >"$tmp/out" 2>/dev/null && [ -s "$tmp/out" ] || return 1
  cat "$tmp/out"
  exit 0
}

dir="$PWD"
while [ "$dir" != "/" ]; do
  if [ -f "$dir/biome.json" ] || [ -f "$dir/biome.jsonc" ]; then
    cd "$dir" || passthrough
    bin="$(find_local_bin biome)" || passthrough
    run_formatter "$bin" format --no-errors-on-unmatched --stdin-file-path="buffer.$ext"
    passthrough
  fi
  if has_prettier_config "$dir"; then
    cd "$dir" || passthrough
    bin="$(find_local_bin prettier)" || passthrough
    run_formatter "$bin" --stdin-filepath="buffer.$ext"
    passthrough
  fi
  dir="$(dirname "$dir")"
done

# No formatter config found, pass through unchanged.
passthrough
